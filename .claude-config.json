{
  "name": "Carpintería 2.0 - Sistema Paramétrico CNC",
  "description": "Sistema que genera muebles paramétricos con nesting automático para CNC",
  "version": "1.0",
  
  "context": {
    "autoLoad": [
      ".claude/INSTRUCTIONS.md",
      ".claude/PROJECT.md",
