  "shortcuts": {
    "runCLI": "python cli.py listar",
    "generateExample": "python cli.py usar escritorio_estandar --mecha 6 --exportar",
    "installDeps": "pip install -r requirements.txt"
  },
  
  "nextSteps": [
    "1. Lee .claude/INSTRUCTIONS.md",
